NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

APP_NAME=Xenog API
CORS_ORIGIN=http://localhost:5173,http://localhost:8081
LOGGER_PROVIDER=dual
LOG_LEVEL=debug
REQUEST_BODY_LIMIT_MB=8

MONGODB_URI=mongodb://root:rootpassword@127.0.0.1:27017/xenogDB?authSource=admin

REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=
REDIS_DB=0

MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=xenog-storage
MINIO_USE_SSL=false
MINIO_PUBLIC_ENDPOINT=10.0.2.2
MINIO_PUBLIC_PORT=9000
MINIO_PUBLIC_USE_SSL=false
AWS_REGION=us-east-1

JWT_ACCESS_SECRET=replace-with-at-least-32-characters-secret
JWT_REFRESH_SECRET=replace-with-at-least-32-characters-refresh-secret
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-strong-password
ADMIN_DISPLAY_NAME=Xenog Admin

RESEND_API_KEY=
EMAIL_FROM="Xenog <no-reply@example.com>"
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=usd
STRIPE_MERCHANT_COUNTRY=US
STRIPE_CONNECT_RETURN_URL=http://10.0.2.2:4000/api/v1/payments/stripe-connect/return
STRIPE_CONNECT_REFRESH_URL=http://10.0.2.2:4000/api/v1/payments/stripe-connect/refresh
STRIPE_CONNECT_APP_RETURN_URL=mooments://profile-screen/add-stripe?stripeConnect=return
STRIPE_CONNECT_APP_REFRESH_URL=mooments://profile-screen/add-stripe?stripeConnect=refresh
STRIPE_CONNECT_ALLOW_CLIENT_REDIRECTS=false

AI_ENGINE_MODE=rules

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
