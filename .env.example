NODE_ENV=production
PORT=5000
API_PREFIX=/api
APP_NAME=Mooment API
APP_ORIGIN=http://mooment.dev
CORS_ORIGIN=http://mooment.dev,http://www.mooment.dev
LOG_LEVEL=info
REQUEST_BODY_LIMIT_MB=2

MONGODB_URI=mongodb://mooment:change-me@mongodb:27017/mooment?authSource=mooment

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me
REDIS_DB=0

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=change-me
AWS_SECRET_ACCESS_KEY=change-me
AWS_S3_BUCKET=your-bucket-name
AWS_S3_PUBLIC_BASE_URL=https://your-bucket-name.s3.us-east-1.amazonaws.com

JWT_ACCESS_SECRET=change-this-to-at-least-32-characters
JWT_REFRESH_SECRET=change-this-to-at-least-32-characters
JWT_ACCESS_TTL_SECONDS=86400
JWT_REFRESH_TTL_SECONDS=2592000

ADMIN_EMAIL=admin@mooment.dev
ADMIN_PASSWORD=change-this-admin-password
ADMIN_DISPLAY_NAME=Mooment Admin

SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=usd
STRIPE_MERCHANT_COUNTRY=US

AI_ENGINE_MODE=rules
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1000
